# ===========================================
# AI Visibility Tracker - Environment Configuration
# ===========================================
# Copy this file to .env and customize

# ===========================================
# DATABASE CONFIGURATION
# ===========================================

# MySQL root password
DB_PASSWORD=rootpassword

# Database name
DB_NAME=ai_visibility


# ===========================================
# AI PROVIDER CONFIGURATION
# ===========================================

# Enabled AI providers (comma-separated)
# Available options: ollama, gemini
# Default: ollama,gemini
AI_PROVIDERS=ollama

# Ollama Configuration
# Model to use for AI queries
# Options: llama3.2, llama3.2:1b, llama3.1, mistral
OLLAMA_MODEL=llama3.2

# Google Gemini Configuration (Optional)
# Get your API key from: https://makersuite.google.com/
# Uncomment and add your key to enable Gemini
# GEMINI_API_KEY=your_api_key_here


# ===========================================
# OPTIONAL: ADVANCED CONFIGURATION
# ===========================================

# Server port (default: 5000)
# PORT=5000

# Node environment
# NODE_ENV=development